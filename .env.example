# Google Gemini API Key
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Pinecone Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=documind-index

# Hugging Face Configuration (Required if EMBEDDING_PROVIDER is huggingface-api)
HF_TOKEN=your_huggingface_hub_token_here

# Embedding Provider Configuration: huggingface-api, huggingface-local, or google-api
# - huggingface-api: Uses Hugging Face Endpoint API (Recommended for Render, consumes 0MB local RAM)
# - huggingface-local: Loads sentence-transformers locally (Requires torch & transformers, uses more RAM)
# - google-api: Uses Google Generative AI embeddings
EMBEDDING_PROVIDER=huggingface-api

# Google LLM Model version (e.g. gemini-2.0-flash, gemini-1.5-pro, etc.)
GEMINI_MODEL=gemini-2.0-flash
